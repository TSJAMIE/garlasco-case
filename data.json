    {
      "id": "antonios",
      "label": "ANTONIO SCOPPETTA",
      "timeline": {
        "2025": {
          "position": { "x": 0, "y": -400},
          "type": "ex Carabiniere del nucleo Forestale", 
          "time": "2025", 
          "eta": "XXXXX",
